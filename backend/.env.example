DEBUG=True
PORT=8000
MOCK_DELAY=3.0
DEFAULT_ADAPTER=volcengine

# 火山引擎参数现在也支持在前端“工具栏 -> 引擎”中配置。
# 这里更适合作为首次启动默认值或无法进入前端时的兜底配置。
VOLCENGINE_ENABLED=False
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=YOUR_ARK_API_KEY
VOLCENGINE_TIMEOUT=180
VOLCENGINE_REQUEST_TIMEOUT=180
VOLCENGINE_VIDEO_TIMEOUT=900
VOLCENGINE_POLL_INTERVAL=3
VOLCENGINE_PROMPT_MODEL=doubao-seed-1-6-251015
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_IMAGE_EDIT_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
VOLCENGINE_IMAGE_OUTPUT_FORMAT=png
VOLCENGINE_WATERMARK=False
PUBLIC_BASE_URL=

COMFYUI_ENABLED=False
COMFYUI_BASE_URL=http://127.0.0.1:8188

# DashScope / 千问 / 万相
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
DASHSCOPE_REQUEST_TIMEOUT=180
DASHSCOPE_VIDEO_TIMEOUT=900
DASHSCOPE_POLL_INTERVAL=3
ENGINE_PROMPT_PROVIDER=volcengine
ENGINE_GENERATE_PROVIDER=volcengine
QWEN_TEXT_MODEL=qwen-plus
QWEN_MULTIMODAL_MODEL=qwen-vl-plus
WANX_IMAGE_MODEL=wan2.7-image-pro
WANX_VIDEO_MODEL=wan2.7-i2v
WANX_VIDEO_RESOLUTION=720P
WANX_WATERMARK=False

# 若万相图生视频要直接使用本地 uploads / outputs 中的首尾帧，可二选一：
# 1. 配置 PUBLIC_BASE_URL，让当前服务生成公网可访问的静态文件 URL
# 2. 或配置下方阿里 OSS，将首尾帧临时上传后生成带签名的 URL
#
# 推荐最简配置，兼容参考项目命名：
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_REGION=cn-shanghai
#
# 如需自定义 endpoint，可额外覆盖：
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_REGION=cn-shanghai
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_KEY_PREFIX=sketchshot-temp
ALIYUN_OSS_SIGNED_URL_EXPIRE_SECONDS=7200
