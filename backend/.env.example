DEBUG=True
PORT=8000
MOCK_DELAY=3.0
DEFAULT_ADAPTER=volcengine

# 火山引擎参数现在也支持在前端“工具栏 -> 引擎”中配置。
# 这里更适合作为首次启动默认值或无法进入前端时的兜底配置。
VOLCENGINE_ENABLED=False
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=YOUR_ARK_API_KEY
VOLCENGINE_TIMEOUT=180
VOLCENGINE_REQUEST_TIMEOUT=180
VOLCENGINE_VIDEO_TIMEOUT=900
VOLCENGINE_POLL_INTERVAL=3
VOLCENGINE_PROMPT_MODEL=doubao-seed-1-6-251015
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_IMAGE_EDIT_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
VOLCENGINE_IMAGE_OUTPUT_FORMAT=png
VOLCENGINE_WATERMARK=False
PUBLIC_BASE_URL=

COMFYUI_ENABLED=False
COMFYUI_BASE_URL=http://127.0.0.1:8188
